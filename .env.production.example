# Copy this file to .env.production on the VPS and fill real values there.
# Do not commit real secrets.

# App
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Europe/Moscow
DOMAIN=bot.example.com
PUBLIC_BASE_URL=https://bot.example.com
WEBHOOK_SECRET=change-this-long-random-secret

# Telegram
TELEGRAM_BOT_TOKEN=change-this
TELEGRAM_ADMIN_ID=123456789
TELEGRAM_USE_WEBHOOK=true
TELEGRAM_STORAGE=postgres
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10

# Telegram Mini App
MINI_APP_ENABLED=true
MINI_APP_PUBLIC_PATH=/miniapp
MINI_APP_AUTH_MAX_AGE_SECONDS=86400
MINI_APP_SESSION_TTL_SECONDS=86400
MINI_APP_COOKIE_NAME=meeting_assistant_mini_app_session
MINI_APP_COOKIE_SECURE=true
MINI_APP_COOKIE_SAMESITE=lax
MINI_APP_FRONTEND_DIST_PATH=frontend/dist

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=meeting_assistant
POSTGRES_USER=meeting_assistant
POSTGRES_PASSWORD=change-this
DATABASE_URL=postgresql+asyncpg://meeting_assistant:change-this@postgres:5432/meeting_assistant

# Google OAuth and Calendar
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://bot.example.com/oauth/google/callback
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_ADMIN_EMAIL=

# Meeting defaults
DEFAULT_MEETING_URL=
BOOKING_HORIZON_DAYS=30
MIN_BOOKING_LEAD_DAYS=1
SLOT_STEP_MINUTES=60
MEETING_BUFFER_MINUTES=90
PENDING_BOOKING_TTL_HOURS=48
CANCELLATION_DEADLINE_HOURS=2
MAX_ACTIVE_BOOKINGS_PER_USER=10

# Legal documents
PERSONAL_DATA_CONSENT_URL=
PERSONAL_DATA_POLICY_URL=

# Worker
WORKER_POLL_INTERVAL_SECONDS=30
INTEGRATION_MAX_RETRIES=3
AUDIT_LOG_RETENTION_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
